generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  billboard Billboard[]
}

model Billboard {
  id            String    @id @default(uuid())

  title         String
  description   String?

  city          String
  location      String

  width          Float?
  height         Float?

  pricePerDay   Float

  imageUrl      String?
  imagePublicId String?

  isActive      Boolean   @default(true)

  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}